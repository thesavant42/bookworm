        "53844": {
            "formats": ["EPUB"],
            "format_sizes": {"EPUB": 749678},
            "authors": ["John Jackson Miller", "Dave Filoni"],
            "languages": ["eng"],
            "publisher": "LucasBooks",
            "tags": [
                "Science Fiction",
                "Space Opera",
                "Video Game Adaptations",
                "Adventure",
                "Action & Adventure",
                "Movie",
                "Star Wars",
                "TV",
                "Science Fiction & Fantasy",
                "Fantasy",
                "Genre Fiction",
